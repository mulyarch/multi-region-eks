name: CI Pipeline

on:
  pull_request:
    branches: [develop, main]
  push:
    branches: [develop]

env:
  AWS_REGION_PRIMARY: us-west-2
  AWS_REGION_SECONDARY: us-east-1
  ECR_REPOSITORY: multi-region-eks-app

permissions:
  id-token: write
  contents: read

jobs:
  validate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Lint Dockerfile
      
